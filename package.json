		"tailwind-merge": "3.2.0",
		"tailwindcss-animate": "1.0.7",
		"vue": "3.5.20",
		"vue-router": "4.5.1",
		"zod": "3.24.3"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "4.1.12",
